# Database Configuration
# Use 'localhost' for native execution, 'db' when running via Docker Compose
DATABASE_URL=postgresql://admin:password@db:5432/resume_db

# AI API Keys (Required)
# Get Google Gemini Key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Get Groq Key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenRouter
OPENROUTER_API_KEY=

# App Settings
PORT=8501
DEBUG=False
